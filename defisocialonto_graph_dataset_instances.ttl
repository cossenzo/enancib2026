defi:Principle10 a defi:ConsumerProtectionPrinciple ;
    defi:description "Protection of Consumer Assets against Fraud, Scams and Misuse"^^xsd:string ;
    defi:number 10 .

defi:Principle9 a defi:ConsumerProtectionPrinciple ;
    defi:description "Responsible Business Conduct and Culture of Financial Services Providers and Intermediaries"^^xsd:string ;
    defi:number 9 .

defi:Principle8 a defi:ConsumerProtectionPrinciple ;
    defi:description "Quality Financial Products"^^xsd:string ;
    defi:number 8 .

defi:approval a defi:LinguisticVariant ;
    defi:expresses defi:tokenApprovalRiskRegister ;
    defi:rawText "approval"^^xsd:string .

defi:Principle7 a defi:ConsumerProtectionPrinciple ;
    defi:description "Disclosure and Transparency"^^xsd:string ;
    defi:number 7 .

defi:impermanentLoss a defi:LinguisticVariant ;
    defi:expresses defi:impermanentLossComprehensionGap ;
    defi:rawText "impermanent loss"^^xsd:string .

defi:ltv a defi:LinguisticVariant ;
    defi:expresses defi:liquidationTechnicalRegister ;
    defi:rawText "LTV"^^xsd:string .

defi:AaveV3 a defi:Protocol ;
    defi:name "Aave v3"^^xsd:string .

defi:Uniswap a defi:Protocol ;
    defi:name "Uniswap"^^xsd:string .

defi:Ethereum a defi:Platform ;
    defi:name "Ethereum"^^xsd:string .

