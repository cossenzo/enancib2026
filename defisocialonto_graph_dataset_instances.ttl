defi:SpeculativeDecisionRisk a defi:Risk ;
    defi:description "Risk that consumers enter high-risk positions impulsively due to hype, FOMO, or group identity."^^xsd:string ;
    defi:isAddressedBy defi:DigitalFinancialLiteracy,
        defi:PlainLanguageRiskExplanation,
        defi:SuitabilityWarning ;
    defi:name "SpeculativeDecisionRisk"^^xsd:string ;
    defi:signals defi:ConsumerDecisionNudge,
        defi:HypeSignalMonitoring,
        defi:SuitabilityRiskScoring .

defi:StablecoinDepegRisk a defi:Risk ;
    defi:description "Risk that a stable or synthetic asset loses parity with its reference asset, reducing user value and confidence."^^xsd:string ;
    defi:isAddressedBy defi:CrisisCommunication,
        defi:PegRiskDisclosure,
        defi:RedemptionInformation ;
    defi:name "StablecoinDepegRisk"^^xsd:string ;
    defi:signals defi:DepegContagionAssessment,
        defi:LiquidityStressSignal,
        defi:PegStabilityMonitoring .

defi:StakeholderImpactAssessment a defi:ActionableForesight ;
    defi:description "Assess distributional impact on users"^^xsd:string ;
    defi:name "StakeholderImpactAssessment"^^xsd:string .

defi:SuitabilityRiskScoring a defi:ActionableForesight ;
    defi:description "Score products or pools by suitability risk"^^xsd:string ;
    defi:name "SuitabilityRiskScoring"^^xsd:string .

defi:TechnicalExplanation a defi:ConsumerProtectionMeasure ;
    defi:description "Explain protocol behavior and failure modes"^^xsd:string ;
    defi:isCoveredBy defi:Principle4,
        defi:Principle7 ;
    defi:name "TechnicalExplanation"^^xsd:string .

defi:TokenIdentityWarning a defi:ConsumerProtectionMeasure ;
    defi:description "Warn users about impersonating tokens"^^xsd:string ;
    defi:isCoveredBy defi:Principle10,
        defi:Principle7 ;
    defi:name "TokenIdentityWarning"^^xsd:string .

defi:TokenListingRiskScreening a defi:ActionableForesight ;
    defi:description "Screen listings for impersonation risk"^^xsd:string ;
    defi:name "TokenListingRiskScreening"^^xsd:string .

defi:TradeSizeDisclosure a defi:ConsumerProtectionMeasure ;
    defi:description "Disclose expected price impact before execution"^^xsd:string ;
    defi:isCoveredBy defi:Principle7,
        defi:Principle8 ;
    defi:name "TradeSizeDisclosure"^^xsd:string .

defi:TradeSizingRecommendation a defi:ActionableForesight ;
    defi:description "Suggest trade sizing to reduce adverse impact"^^xsd:string ;
    defi:name "TradeSizingRecommendation"^^xsd:string .

defi:TransactionPreview a defi:ConsumerProtectionMeasure ;
    defi:description "Preview transaction outcomes before signing"^^xsd:string ;
    defi:isCoveredBy defi:Principle10,
        defi:Principle7,
        defi:Principle8 ;
    defi:name "TransactionPreview"^^xsd:string .

defi:UnsafeContractScreening a defi:ActionableForesight ;
    defi:description "Screen contracts for excessive permissions"^^xsd:string ;
    defi:name "UnsafeContractScreening"^^xsd:string .

defi:VerificationGuidance a defi:ConsumerProtectionMeasure ;
    defi:description "Guide verification of token address and issuer"^^xsd:string ;
    defi:isCoveredBy defi:Principle10,
        defi:Principle4 ;
    defi:name "VerificationGuidance"^^xsd:string .

defi:VoterInformation a defi:ConsumerProtectionMeasure ;
    defi:description "Provide concise information to voters and affected users"^^xsd:string ;
    defi:isCoveredBy defi:Principle4,
        defi:Principle7 ;
    defi:name "VoterInformation"^^xsd:string .

defi:VotingPowerDisclosure a defi:ConsumerProtectionMeasure ;
    defi:description "Show who can shape decisions"^^xsd:string ;
    defi:isCoveredBy defi:Principle7,
        defi:Principle9 ;
    defi:name "VotingPowerDisclosure"^^xsd:string .

defi:WalletDrainClusterDetection a defi:ActionableForesight ;
    defi:description "Detect clusters of wallet-loss reports"^^xsd:string ;
    defi:name "WalletDrainClusterDetection"^^xsd:string .

defi:WalletDrainRisk a defi:Risk ;
    defi:description "Risk of user asset loss through phishing, malicious approvals, compromised keys, or unsafe interfaces."^^xsd:string ;
    defi:isAddressedBy defi:IncidentGuidance,
        defi:SecurityWarning,
        defi:SupportTriage ;
    defi:name "WalletDrainRisk"^^xsd:string ;
    defi:signals defi:ConsumerHarmEscalation,
        defi:PhishingCampaignMonitoring,
        defi:WalletDrainClusterDetection .

defi:WalletSafetyAlert a defi:ActionableForesight ;
    defi:description "Alert users and ecosystem actors about unsafe signing flows"^^xsd:string ;
    defi:name "WalletSafetyAlert"^^xsd:string .

defi:YieldDisclosure a defi:ConsumerProtectionMeasure ;
    defi:description "Disclose that fees may not offset relative loss"^^xsd:string ;
    defi:isCoveredBy defi:Principle7,
        defi:Principle8 ;
    defi:name "YieldDisclosure"^^xsd:string .

defi:collateralEfficiencyRiskRegister a defi:Concept ;
    defi:description "Technical vocabulary that presents capital efficiency, borrowing capacity, or collateral optimization while also implying amplified liquidation exposure."^^xsd:string ;
    defi:isAssociatedWith defi:ExcessiveLeverageRisk ;
    defi:name "Collateral-efficiency risk register"^^xsd:string .

defi:collateralRiskConstraintRegister a defi:Concept ;
    defi:description "Technical vocabulary describing collateral restrictions, isolation rules, eligibility limits, and constraints that affect user flexibility and liquidation exposure."^^xsd:string ;
    defi:isAssociatedWith defi:CollateralConstraintRisk ;
    defi:name "Collateral-risk constraint register"^^xsd:string .

defi:contractAndTransactionRugPullPattern a defi:Concept ;
    defi:description "Signals in contract behavior or transaction sequences that suggest liquidity removal, project abandonment, or exit-oriented exploitation."^^xsd:string ;
    defi:isAssociatedWith defi:LiquidityRemovalRisk ;
    defi:name "Contract and transaction rug-pull pattern"^^xsd:string .

defi:governanceDeliberationRegister a defi:Concept ;
    defi:description "Terminology related to proposal review, debate quality, information asymmetry, and collective decision-making in protocol governance."^^xsd:string ;
    defi:isAssociatedWith defi:GovernanceDecisionRisk ;
    defi:name "Governance deliberation register"^^xsd:string .

defi:governanceExecutionControlRegister a defi:Concept ;
    defi:description "Terminology concerning timelocks, execution delays, proposal activation, and procedural safeguards before governance decisions become effective."^^xsd:string ;
    defi:isAssociatedWith defi:GovernanceExecutionRisk ;
    defi:name "Governance execution-control register"^^xsd:string .

defi:liquidityRemoval a defi:LinguisticVariant ;
    defi:expresses defi:contractAndTransactionRugPullPattern ;
    defi:rawText "liquidity removal"^^xsd:string .

defi:protocolRiskParameterRegister a defi:Concept ;
    defi:description "Technical vocabulary concerning protocol parameters whose configuration can increase exposure to liquidation, liquidity stress, or market instability."^^xsd:string ;
    defi:isAssociatedWith defi:RiskParameterMisconfigurationRisk ;
    defi:name "Protocol-risk parameter register"^^xsd:string .

defi:CrisisCommunication a defi:ConsumerProtectionMeasure ;
    defi:description "Communicate exceptional measures clearly"^^xsd:string ;
    defi:isCoveredBy defi:Principle12,
        defi:Principle7,
        defi:Principle9 ;
    defi:name "CrisisCommunication"^^xsd:string .

defi:ExecutionQualityBenchmarking a defi:ActionableForesight ;
    defi:description "Compare execution quality across routes, venues, or transaction contexts"^^xsd:string ;
    defi:name "ExecutionQualityBenchmarking"^^xsd:string .

defi:ExecutionQualityWarning a defi:ConsumerProtectionMeasure ;
    defi:description "Warn users about adverse transaction ordering"^^xsd:string ;
    defi:isCoveredBy defi:Principle6,
        defi:Principle7 ;
    defi:name "ExecutionQualityWarning"^^xsd:string .

defi:MaliciousApprovalRisk a defi:Risk ;
    defi:description "Risk that token permissions or signatures enable unauthorized or excessive asset transfers."^^xsd:string ;
    defi:isAddressedBy defi:ApprovalWarning,
        defi:PermissionReview,
        defi:RevocationSupport ;
    defi:name "MaliciousApprovalRisk"^^xsd:string ;
    defi:signals defi:ApprovalRiskMonitoring,
        defi:UnsafeContractScreening,
        defi:WalletSafetyAlert .

defi:SlippageProtection a defi:ConsumerProtectionMeasure ;
    defi:description "Encourage protective slippage and routing settings"^^xsd:string ;
    defi:isCoveredBy defi:Principle6,
        defi:Principle7,
        defi:Principle8 ;
    defi:name "SlippageProtection"^^xsd:string .

defi:SupportTriage a defi:ConsumerProtectionMeasure ;
    defi:description "Route users to support and resolution channels"^^xsd:string ;
    defi:isCoveredBy defi:Principle12 ;
    defi:name "SupportTriage"^^xsd:string .

defi:executionQualityRegister a defi:Concept ;
    defi:description "Language used to assess trade execution conditions, including price movement, route quality, expected output, and realized transaction outcomes."^^xsd:string ;
    defi:isAssociatedWith defi:PriceImpactRisk,
        defi:SlippageRisk ;
    defi:name "Execution-quality register"^^xsd:string .

defi:fakeToken a defi:LinguisticVariant ;
    defi:expresses defi:scamTokenDeceptionFrame ;
    defi:rawText "fake token"^^xsd:string .

defi:fraudAccusationFrame a defi:Concept ;
    defi:description "Accusatory language that interprets project abandonment, insider selling, liquidity removal, or consumer losses as intentional fraud or exit behavior."^^xsd:string ;
    defi:isAssociatedWith defi:RugPullRisk ;
    defi:name "Fraud accusation frame"^^xsd:string .

defi:frontRun a defi:LinguisticVariant ;
    defi:expresses defi:mevFairnessFrame ;
    defi:rawText "front-run"^^xsd:string .

defi:governanceAttackFrame a defi:Concept ;
    defi:description "Language that represents protocol governance as vulnerable to hostile proposals, takeovers, vote manipulation, or strategic exploitation."^^xsd:string ;
    defi:isAssociatedWith defi:GovernanceAttackRisk ;
    defi:name "Governance-attack frame"^^xsd:string .

defi:governanceCaptureAndLegitimacyFrame a defi:Concept ;
    defi:description "Discourse that questions whether protocol governance is controlled by concentrated voting power, insiders, or actors with disproportionate influence."^^xsd:string ;
    defi:isAssociatedWith defi:GovernanceCaptureRisk ;
    defi:name "Governance capture and legitimacy frame"^^xsd:string .

defi:impermanentLossComprehensionGap a defi:Concept ;
    defi:description "Expressions indicating that users may misunderstand how liquidity provision can underperform simple holding when asset prices diverge."^^xsd:string ;
    defi:isAssociatedWith defi:ImpermanentLossRisk ;
    defi:name "Impermanent-loss comprehension gap"^^xsd:string .

defi:oracleDependenceRiskRegister a defi:Concept ;
    defi:description "Terminology describing reliance on price feeds, oracle updates, data freshness, and external price inputs for protocol decisions."^^xsd:string ;
    defi:isAssociatedWith defi:OracleFailureRisk ;
    defi:name "Oracle-dependence risk register"^^xsd:string .

defi:protocolFailureBlameFrame a defi:Concept ;
    defi:description "Language that attributes consumer losses to protocol design, parameter choices, or system behavior rather than to external attackers."^^xsd:string ;
    defi:isAssociatedWith defi:ProtocolFailureRisk ;
    defi:name "Protocol-failure blame frame"^^xsd:string .

defi:scamTokenDeceptionFrame a defi:Concept ;
    defi:description "Language that identifies deceptive, impersonating, or misleading tokens as mechanisms for confusing users and inducing financial loss."^^xsd:string ;
    defi:isAssociatedWith defi:ScamTokenRisk ;
    defi:name "Scam-token deception frame"^^xsd:string .

defi:stablecoinCrisisAlarm a defi:Concept ;
    defi:description "Warning-oriented language that signals loss of peg, liquidity stress, contagion concerns, or urgent instability around stable or synthetic assets."^^xsd:string ;
    defi:isAssociatedWith defi:StablecoinDepegRisk ;
    defi:name "Stablecoin crisis alarm"^^xsd:string .

defi:FairnessMonitoring a defi:ConsumerProtectionMeasure ;
    defi:description "Monitor fairness of transaction execution"^^xsd:string ;
    defi:isCoveredBy defi:Principle2,
        defi:Principle6,
        defi:Principle9 ;
    defi:name "FairnessMonitoring"^^xsd:string .

defi:SuitabilityWarning a defi:ConsumerProtectionMeasure ;
    defi:description "Assess appropriateness of high borrowing exposure"^^xsd:string ;
    defi:isCoveredBy defi:Principle6,
        defi:Principle8,
        defi:Principle9 ;
    defi:name "SuitabilityWarning"^^xsd:string .

defi:emergencyGovernanceRegister a defi:Concept ;
    defi:description "Language used to describe urgent protocol or governance interventions during stress, including emergency votes, rapid parameter changes, or protective actions."^^xsd:string ;
    defi:isAssociatedWith defi:CrisisGovernanceRisk ;
    defi:name "Emergency governance register"^^xsd:string .

defi:harmedUserWalletLossNarrative a defi:Concept ;
    defi:description "User-centered accounts of asset loss involving drained wallets, compromised access, phishing, unsafe interfaces, or unexplained transfers."^^xsd:string ;
    defi:isAssociatedWith defi:MaliciousApprovalRisk,
        defi:WalletDrainRisk ;
    defi:name "Harmed-user wallet-loss narrative"^^xsd:string .

defi:speculativeIdentityMarker a defi:Concept ;
    defi:description "Language that frames high-risk participation as part of a shared speculative identity, often reinforcing hype, FOMO, or group belonging."^^xsd:string ;
    defi:isAssociatedWith defi:SpeculativeDecisionRisk ;
    defi:name "Speculative identity marker"^^xsd:string .

defi:tokenApprovalRiskRegister a defi:Concept ;
    defi:description "Technical vocabulary used to describe token permissions, signatures, allowances, and approval flows that may expose users to unauthorized transfers."^^xsd:string ;
    defi:isAssociatedWith defi:MaliciousApprovalRisk ;
    defi:name "Token-approval risk register"^^xsd:string .

defi:mev a defi:LinguisticVariant ;
    defi:expresses defi:mevFairnessFrame ;
    defi:rawText "MEV"^^xsd:string .

defi:mevFairnessFrame a defi:Concept ;
    defi:description "Discourse that evaluates transaction ordering, priority, and execution advantages as fairness problems affecting consumer outcomes."^^xsd:string ;
    defi:isAssociatedWith defi:FrontRunningRisk,
        defi:MEVExtractionRisk,
        defi:SandwichAttackRisk ;
    defi:name "MEV fairness frame"^^xsd:string .

defi:priceImpact a defi:LinguisticVariant ;
    defi:expresses defi:executionQualityRegister ;
    defi:rawText "price impact"^^xsd:string .

defi:Principle2 a defi:ConsumerProtectionPrinciple ;
    defi:description "Role of Oversight Bodies"^^xsd:string ;
    defi:number 2 .

defi:ghoDepeg a defi:LinguisticVariant ;
    defi:expresses defi:stablecoinCrisisAlarm ;
    defi:rawText "GHO depeg"^^xsd:string .

defi:liquidationTechnicalRegister a defi:Concept ;
    defi:description "Specialized terminology for collateral ratios, health factors, liquidation thresholds, and automated position closure in lending protocols."^^xsd:string ;
    defi:isAssociatedWith defi:ForcedLiquidationRisk ;
    defi:name "Liquidation technical register"^^xsd:string .

defi:Principle4 a defi:ConsumerProtectionPrinciple ;
    defi:description "Financial Literacy and Awareness"^^xsd:string ;
    defi:number 4 .

