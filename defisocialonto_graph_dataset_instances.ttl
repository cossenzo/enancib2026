    defi:description "Equitable and Fair Treatment of Consumers"^^xsd:string ;
    defi:number 6 .

defi:Principle12 a defi:ConsumerProtectionPrinciple ;
    defi:description "Complaints Handling and Redress"^^xsd:string ;
