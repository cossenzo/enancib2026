    defi:description "Alert consumers to deceptive token listings"^^xsd:string ;
    defi:isCoveredBy defi:Principle10,
        defi:Principle7 ;
    defi:name "ScamTokenAlert"^^xsd:string .

defi:ScamTokenRisk a defi:Risk ;
    defi:description "Risk that deceptive or impersonating tokens mislead consumers and cause financial loss."^^xsd:string ;
    defi:isAddressedBy defi:ScamTokenAlert,
        defi:TokenIdentityWarning,
        defi:VerificationGuidance ;
    defi:name "ScamTokenRisk"^^xsd:string ;
    defi:signals defi:ImpersonationMonitoring,
        defi:ScamNarrativeTracking,
        defi:TokenListingRiskScreening .

defi:SecurityWarning a defi:ConsumerProtectionMeasure ;
    defi:description "Warn about phishing, unsafe approvals, and key compromise"^^xsd:string ;
    defi:isCoveredBy defi:Principle10 ;
    defi:name "SecurityWarning"^^xsd:string .

defi:SlippageMonitoring a defi:ActionableForesight ;
    defi:description "Monitor realized slippage"^^xsd:string ;
    defi:name "SlippageMonitoring"^^xsd:string .

defi:SlippageRisk a defi:Risk ;
    defi:description "Risk that the executed transaction price differs materially from the expected price."^^xsd:string ;
    defi:isAddressedBy defi:ExpectedPriceDisclosure,
        defi:SlippageWarning,
        defi:TransactionPreview ;
    defi:name "SlippageRisk"^^xsd:string ;
    defi:signals defi:ExecutionRiskAlert,
        defi:RouteQualityBenchmarking,
        defi:SlippageMonitoring .

defi:SlippageWarning a defi:ConsumerProtectionMeasure ;
    defi:description "Warn when expected and executed prices may diverge"^^xsd:string ;
    defi:isCoveredBy defi:Principle7,
        defi:Principle8 ;
    defi:name "SlippageWarning"^^xsd:string .

