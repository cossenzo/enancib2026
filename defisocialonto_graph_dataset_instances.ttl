defi:ApprovalRiskMonitoring a defi:ActionableForesight ;
    defi:description "Track abnormal approval patterns"^^xsd:string ;
    defi:name "ApprovalRiskMonitoring"^^xsd:string .

defi:ApprovalWarning a defi:ConsumerProtectionMeasure ;
    defi:description "Warn users about token permissions before signing"^^xsd:string ;
    defi:isCoveredBy defi:Principle10,
        defi:Principle7 ;
    defi:name "ApprovalWarning"^^xsd:string .

defi:CollateralConstraintDisclosure a defi:ConsumerProtectionMeasure ;
    defi:description "Explain restrictions of collateral modes"^^xsd:string ;
    defi:isCoveredBy defi:Principle7,
        defi:Principle8 ;
    defi:name "CollateralConstraintDisclosure"^^xsd:string .

defi:CollateralConstraintMonitoring a defi:ActionableForesight ;
    defi:description "Monitor restricted collateral exposure"^^xsd:string ;
    defi:name "CollateralConstraintMonitoring"^^xsd:string .

defi:CollateralConstraintRisk a defi:Risk ;
    defi:description "Risk that collateral restrictions or isolation rules limit user flexibility and increase liquidation or liquidity exposure."^^xsd:string ;
    defi:isAddressedBy defi:CollateralConstraintDisclosure,
        defi:LiquidityExitGuidance,
        defi:PositionRiskWarning ;
    defi:name "CollateralConstraintRisk"^^xsd:string ;
    defi:signals defi:CollateralConstraintMonitoring,
        defi:ExitFeasibilityAssessment,
        defi:IsolationModeRiskBenchmark .

defi:CollateralEfficiencyBenchmark a defi:ActionableForesight ;
    defi:description "Compare collateral modes by risk efficiency"^^xsd:string ;
    defi:name "CollateralEfficiencyBenchmark"^^xsd:string .

defi:CollateralHealthWarning a defi:ConsumerProtectionMeasure ;
    defi:description "Warn when collateral position approaches unsafe thresholds"^^xsd:string ;
    defi:isCoveredBy defi:Principle7,
        defi:Principle8 ;
    defi:name "CollateralHealthWarning"^^xsd:string .

defi:CollateralParameterDisclosure a defi:ConsumerProtectionMeasure ;
    defi:description "Disclose collateral efficiency and risk parameters"^^xsd:string ;
    defi:isCoveredBy defi:Principle7,
        defi:Principle8 ;
    defi:name "CollateralParameterDisclosure"^^xsd:string .

defi:CollateralStressTesting a defi:ActionableForesight ;
    defi:description "Simulate collateral price shocks"^^xsd:string ;
    defi:name "CollateralStressTesting"^^xsd:string .

defi:ConsumerAlert a defi:ConsumerProtectionMeasure ;
    defi:description "Alert consumers about suspected rug-pull indicators"^^xsd:string ;
    defi:isCoveredBy defi:Principle10,
        defi:Principle4,
        defi:Principle7 ;
    defi:name "ConsumerAlert"^^xsd:string .

defi:ConsumerDecisionNudge a defi:ActionableForesight ;
    defi:description "Suggest safer decision prompts before entry"^^xsd:string ;
    defi:name "ConsumerDecisionNudge"^^xsd:string .

defi:ConsumerHarmEscalation a defi:ActionableForesight ;
    defi:description "Escalate repeated consumer harm for investigation"^^xsd:string ;
    defi:name "ConsumerHarmEscalation"^^xsd:string .

defi:ConsumerImpactAssessment a defi:ActionableForesight ;
    defi:description "Estimate consumer harm and remediation needs"^^xsd:string ;
    defi:name "ConsumerImpactAssessment"^^xsd:string .

defi:CrisisGovernanceRisk a defi:Risk ;
    defi:description "Risk that urgent governance or protocol actions during stress create uncertainty, errors, or unequal protection."^^xsd:string ;
    defi:isAddressedBy defi:CrisisCommunication,
        defi:EmergencyDecisionDisclosure,
        defi:ManualReview ;
    defi:name "CrisisGovernanceRisk"^^xsd:string ;
    defi:signals defi:CrisisSignalMonitoring,
        defi:EmergencyGovernanceAudit,
        defi:StakeholderImpactAssessment .

defi:CrisisSignalMonitoring a defi:ActionableForesight ;
    defi:description "Track crisis language and urgent proposals"^^xsd:string ;
    defi:name "CrisisSignalMonitoring"^^xsd:string .

defi:DecisionQualityReview a defi:ActionableForesight ;
    defi:description "Review decision quality after implementation"^^xsd:string ;
    defi:name "DecisionQualityReview"^^xsd:string .

defi:DefenseReadinessAssessment a defi:ActionableForesight ;
    defi:description "Assess readiness for emergency response"^^xsd:string ;
    defi:name "DefenseReadinessAssessment"^^xsd:string .

defi:DelayAdequacyAssessment a defi:ActionableForesight ;
    defi:description "Assess whether delay is sufficient"^^xsd:string ;
    defi:name "DelayAdequacyAssessment"^^xsd:string .

defi:DelegationStrategyReview a defi:ActionableForesight ;
    defi:description "Review delegation or participation strategies"^^xsd:string ;
    defi:name "DelegationStrategyReview"^^xsd:string .

defi:DeleveragingSignal a defi:ActionableForesight ;
    defi:description "Suggest debt repayment or collateral reinforcement decisions"^^xsd:string ;
    defi:name "DeleveragingSignal"^^xsd:string .

defi:DeliberationSupport a defi:ConsumerProtectionMeasure ;
    defi:description "Support informed deliberation"^^xsd:string ;
    defi:isCoveredBy defi:Principle6,
        defi:Principle7 ;
    defi:name "DeliberationSupport"^^xsd:string .

defi:DepegContagionAssessment a defi:ActionableForesight ;
    defi:description "Assess cross-protocol contagion risk"^^xsd:string ;
    defi:name "DepegContagionAssessment"^^xsd:string .

defi:DigitalFinancialLiteracy a defi:ConsumerProtectionMeasure ;
    defi:description "Educate users about FOMO and leveraged speculation"^^xsd:string ;
    defi:isCoveredBy defi:Principle4 ;
    defi:name "DigitalFinancialLiteracy"^^xsd:string .

defi:DivergenceLossSimulation a defi:ActionableForesight ;
    defi:description "Simulate price-divergence scenarios"^^xsd:string ;
    defi:name "DivergenceLossSimulation"^^xsd:string .

defi:EmergencyDecisionDisclosure a defi:ConsumerProtectionMeasure ;
    defi:description "Disclose emergency decision rationale and consequences"^^xsd:string ;
    defi:isCoveredBy defi:Principle7,
        defi:Principle9 ;
    defi:name "EmergencyDecisionDisclosure"^^xsd:string .

defi:EmergencyGovernanceAudit a defi:ActionableForesight ;
    defi:description "Audit emergency governance actions"^^xsd:string ;
    defi:name "EmergencyGovernanceAudit"^^xsd:string .

defi:ExcessiveLeverageRisk a defi:Risk ;
    defi:description "Risk that efficiency-oriented collateral parameters encourage borrowing exposure that amplifies liquidation losses."^^xsd:string ;
    defi:isAddressedBy defi:CollateralParameterDisclosure,
        defi:LeverageWarning,
        defi:SuitabilityWarning ;
    defi:name "ExcessiveLeverageRisk"^^xsd:string ;
    defi:signals defi:CollateralEfficiencyBenchmark,
        defi:LeverageExposureMonitoring,
        defi:LiquidationLossForecast .

defi:ExecutionCostBenchmarking a defi:ActionableForesight ;
    defi:description "Compare implicit execution costs"^^xsd:string ;
    defi:name "ExecutionCostBenchmarking"^^xsd:string .

defi:ExecutionDelayControl a defi:ConsumerProtectionMeasure ;
    defi:description "Use delay controls to allow mitigation before execution"^^xsd:string ;
    defi:isCoveredBy defi:Principle10,
        defi:Principle9 ;
    defi:name "ExecutionDelayControl"^^xsd:string .

