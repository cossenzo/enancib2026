    defi:rawText "...following formula: APR = f(min(USDC debt, cbBTC value * max LTV) This formula considers the lower value between the user's USDC debt and the maximum loan-to-value (LTV) for their cbBTC holdings."^^xsd:string ;
    defi:refersToPlatform defi:Ethereum ;
    defi:refersToProtocol defi:AaveV3 .

